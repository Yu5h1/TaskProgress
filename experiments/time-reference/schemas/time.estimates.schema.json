{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taskprogress.local/schemas/time-reference/time.estimates.schema.json",
  "title": "TaskProgress Time Estimates (Draft)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope_id", "updated_at", "estimates"],
  "properties": {
    "schema_version": {
      "const": "0.2"
    },
    "scope_id": {
      "$ref": "#/$defs/id"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "estimates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/estimate"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "contributor_kind": {
      "type": "string",
      "enum": [
        "human_estimate",
        "human_parameter",
        "ai_analysis",
        "historical_evidence",
        "system_default",
        "deterministic_formula"
      ]
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/contributor_kind"
        },
        "summary": {
          "type": "string",
          "maxLength": 500
        },
        "reference": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "input_parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "origin"],
      "properties": {
        "name": {
          "$ref": "#/$defs/id"
        },
        "value": {
          "type": ["number", "string", "boolean"]
        },
        "unit": {
          "type": "string",
          "maxLength": 50
        },
        "origin": {
          "type": "string",
          "enum": ["human", "ai", "historical", "default"]
        },
        "note": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "analysis_method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "performed_by", "explanation"],
      "properties": {
        "name": {
          "$ref": "#/$defs/id"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "performed_by": {
          "type": "string",
          "enum": ["ai", "human", "system"]
        },
        "explanation": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "calculation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm_id", "formula", "version", "explanation"],
      "properties": {
        "algorithm_id": {
          "$ref": "#/$defs/id"
        },
        "formula": {
          "type": "string",
          "maxLength": 500
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "explanation": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimate_id",
        "task_id",
        "likely_minutes",
        "contributors",
        "human_confirmed",
        "confidence",
        "estimated_at",
        "active"
      ],
      "dependentRequired": {
        "low_minutes": ["high_minutes"],
        "high_minutes": ["low_minutes"]
      },
      "properties": {
        "estimate_id": {
          "$ref": "#/$defs/id"
        },
        "task_id": {
          "$ref": "#/$defs/id"
        },
        "item_id": {
          "$ref": "#/$defs/id"
        },
        "low_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "likely_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "high_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "contributors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/contributor"
          }
        },
        "human_confirmed": {
          "type": "boolean",
          "description": "True only when a human accepted the final estimate result. Human inputs do not imply confirmation."
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_parameter"
          }
        },
        "analysis_method": {
          "$ref": "#/$defs/analysis_method"
        },
        "calculation": {
          "$ref": "#/$defs/calculation"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "estimated_at": {
          "type": "string",
          "format": "date-time"
        },
        "active": {
          "type": "boolean",
          "description": "Only one estimate may be active for the same task/item target."
        },
        "template_id": {
          "$ref": "#/$defs/id"
        },
        "effective_sample_count": {
          "type": "number",
          "minimum": 0
        },
        "derived_from_estimate_id": {
          "$ref": "#/$defs/id"
        },
        "supersedes_estimate_id": {
          "$ref": "#/$defs/id"
        },
        "rationale": {
          "type": "string",
          "maxLength": 1000
        },
        "human_note": {
          "type": "string",
          "maxLength": 1000
        },
        "reference": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  }
}
