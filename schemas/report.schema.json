{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://task-progress.local/schemas/report.schema.json",
  "title": "TaskProgress Viewer Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "scope_id",
    "title",
    "updated_at",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "report_id": {
      "$ref": "#/$defs/id"
    },
    "scope_id": {
      "$ref": "#/$defs/id"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 100
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "status": {
          "enum": ["planned", "in_progress", "blocked", "done", "archive"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "completed_items": {
          "$ref": "#/$defs/itemList"
        },
        "pending_items": {
          "$ref": "#/$defs/itemList"
        },
        "progress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["completed", "total"],
          "properties": {
            "completed": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "itemList": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          {
            "$ref": "#/$defs/item"
          }
        ]
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    }
  }
}
