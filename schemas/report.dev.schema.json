{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://task-progress.local/schemas/report.dev.schema.json",
  "title": "TaskProgress Developer Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "updated_at", "tasks"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "report_id": {
      "$ref": "#/$defs/id"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/taskOverlay"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 100
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "taskOverlay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "next_step": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "next_steps": {
          "$ref": "#/$defs/stringList",
          "deprecated": true
        },
        "blockers": {
          "$ref": "#/$defs/stringList"
        },
        "decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decision"
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "claim": {
          "$ref": "#/$defs/claim"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "state"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "state": {
          "enum": ["candidate", "selected", "rejected"]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent"],
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "worktree": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "source_paths": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  }
}
